    "# Learn more about kagglehub: https://github.com/Kaggle/kagglehub/blob/main/README.md\n",
    "\n",
    "import kagglehub\n",
    "df = pd.read_csv('/kaggle/input/datasets/vishardmehta/e-commerce-customer-churn-prediction-dataset/ecommerce_customer_features.csv')\n",
    "df1 = pd.read_csv('/kaggle/input/datasets/vishardmehta/e-commerce-customer-churn-prediction-dataset/ecommerce_customer_targets.csv')\n",
    "# kagglehub.dataset_download('<owner>/<dataset-slug>')\n",
    "query = \"\"\"\n",
    "SELECT d.account_age_months, d.avg_order_value, d.total_orders, d.return_rate, d.browsing_frequency_per_week,\n",
    "    \n",
    "    CASE\n",
    "        WHEN t.churned = 'Yes' THEN 1\n",
    "        ELSE 0\n",
    "    END AS churned\n",
    "FROM df d\n",
    "JOIN df1 t\n",
    "ON d.Customer_ID = t.Customer_ID\n",
    "\"\"\"\n",
    "result = sqldf(query)\n",
    "print(result)\n",
    "result.to_csv('/kaggle/working/result1.csv', index=False)\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    churned,\n",
    "    COUNT(*) AS num_customers,\n",
    "    AVG(account_age_months) AS avg_account_months,\n",
    "    AVG(avg_order_value) AS avg_order_value_by_churned,\n",
    "    AVG(total_orders) AS avg_total_orders,\n",
    "    AVG(return_rate) AS avg_return_rate,\n",
    "    AVG(browsing_frequency_per_week) AS avg_browsing_frequency_per_week\n",
    "FROM result\n",
    "GROUP BY churned;\n",
    "\"\"\"\n",
    "output = sqldf(query)\n",
    "print(output)\n",
    "output.to_csv('/kaggle/working/result6.csv', index=False)\n",
    "\n",
    "query = \"\"\"\n",
